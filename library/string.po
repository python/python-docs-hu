msgid ":mod:`!string` --- Common string operations"
msgstr ""

msgid "**Source code:** :source:`Lib/string.py`"
msgstr "**Kod źródłowy:** :source:`Lib/string.py`"

msgid ":ref:`textseq`"
msgstr ":ref:`textseq`"

